# Required
BOT_TOKEN=your_telegram_bot_token
ALLOWED_USERS=123456789  # comma-separated Telegram user IDs, leave empty to allow all

# Optional
SYSTEM_PROMPT=You are a helpful coding assistant.
WORKING_DIR=/path/to/your/project
MODEL=sonnet  # haiku, sonnet, or opus
RATE_LIMIT=5  # max requests per user per minute
CHAT_DIRS={}  # JSON: per-chat working dirs, e.g. {"123456": "~/project-a", "789012": "~/project-b"}
